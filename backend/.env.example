# Database
DATABASE_URL=postgresql://ticketmeter:ticketmeter@localhost:5432/ticketmeter
# For local SQLite dev: DATABASE_URL=sqlite:///./ticketmeter.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Ticket APIs
SEATGEEK_CLIENT_ID=
SEATGEEK_SECRET=
TICKETMASTER_API_KEY=

# News
NEWSAPI_KEY=

# Email (Resend)
RESEND_API_KEY=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@ticketmeter.app

# Environment
ENVIRONMENT=development
USE_MOCK_DATA=true
