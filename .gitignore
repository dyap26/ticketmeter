*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# SQLite dev database
*.db
*.sqlite3

# Alembic
